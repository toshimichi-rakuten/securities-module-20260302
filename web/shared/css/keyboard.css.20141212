#keyboard_body {
	display: none;
	font-size: 18px !important;
	padding: 0 !important;
}
#keyboard_body .keyboard-tab {
	height: 33px;
	position: relative;
	font-size: 12px !important;
	margin-top: 10px;
	background: url(../images/sprite_key.png) no-repeat;
	background-position: 0 -522px;
}
#keyboard_body .keyboard-tab a {
	padding-left: 10px;
	background: url(../images/sprite_key.png) no-repeat top left;
	background-position: 0 -469px;
}
#keyboard_body .key-group {
	background-color: #DEDEF5;
	margin-bottom: 0.2em;
	padding: 0.4em 0 0 0.1em;
	margin: 0 0.5em 0.6em 0.5em;
	overflow: hidden;
}
#keyboard_body div {
	margin-bottom: 0.3em;
}
#keyboard_body .ui-dialog-buttonpane {
	background-color: #6671B3;
}
html>/**/body .keyboard_button {
	margin-bottom /***/: 5px\9;
}
.keyboard_button {
	font-size: 18px !important;
	width: 27px;
	height: 27px;
	margin-left: 5px;
	padding: 0 !important;
	border: 0 !important;
	background: url(../images/sprite_key.png) no-repeat top left;
	background-position: 0 -92px;
}
.keyboard_button:hover {
	background: url(../images/sprite_key.png) no-repeat top left;
	background-position: 0 -189px;
}