var cbInfo = function(flg, key, txt, sch, cnt) {
  this.flg = flg;
  this.key = key;
  this.txt = txt;
  this.sch = sch;
  this.cnt = cnt;
}

cbInfo.prototype = {
  setON : function () {
    this.flg = 1;
    $("input[name=" + this.key + "]").attr("checked", true);
  },
  setOFF : function() {
    this.flg = 0;
    $("input[name=" + this.key + "]").attr("checked", false);
  },
  toHtml : function() {
//  return "<li><label><input type=\"checkbox\" name=\"" + this.key + "\" />" + this.txt + "<span class=\"number\">(" + this.cnt +")</span></label></li>";
    return "<li><label><input type=\"checkbox\" name=\"" + this.key + "\" />" + this.txt + "</label></li>";
  }
};

var sort_by = function(field, reverse, primer){
   reverse = (reverse) ? -1 : 1;
   return function(a,b){
     if(primer == parseFloat) {
       a = a[field];
       b = b[field];
       if(reverse == 1){
         if(a=='NA') a = 99999;
         if(b=='NA') b = 99999;
       } else {
         if(a=='NA') a = -99999;
         if(b=='NA') b = -99999;
       }
     }else{
       a = a[field];
       b = b[field];
     }

     if (typeof(primer) != 'undefined'){
       a = primer(a);
       b = primer(b);
     }
     if (a<b) return reverse * -1;
     if (a>b) return reverse * 1;
     return 0;
  }
}

