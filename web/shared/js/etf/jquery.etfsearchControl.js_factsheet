  $(".btn-search").click(function() {
    // ETF検索項目抽出処理
      etf_fetch();

    // ETF一覧表示処理
    etf_list();
  });

  $("li",".btn-search-lower").eq(0).click(function() {
    // ETF検索項目抽出処理
    etf_fetch();

    // ETF一覧表示処理
    etf_list();
  });

  // クリアボタンで項目初期化(
  $("li",".btn-search-lower").eq(1).click(function() {
    $("input[type='text'], textarea").not("input[readonly='true'], input[type='hidden'], :button, :submit, :reset").val("");
    $("input[type='radio'], input[type='checkbox'], select").removeAttr("checked").removeAttr("selected");
    $("select option:first-child").attr("selected", "selected");
  })
  // ---- COOKIE＆イベント処理 ----

})
function sortList(flg, fld)
{
  if(fld == 'NetAssetValue') {
    tmpETFDB.sort(sort_by(fld, flg, parseFloat));
  } else if((fld=='Return1w') || (fld=='Return1m') || (fld=='Return3m') || (fld=='Return1y') || (fld=='ReturnYTD') || (fld=='DividendYeild') || (fld=='ExpenseRatio')){ 
    tmpETFDB.sort(sort_by(fld, flg, parseFloat));
  } else {
    tmpETFDB.sort(sort_by(fld, flg, function(a){return a.toUpperCase()}));
  }

  // ETF一覧表示処理
  etf_list();
}

function setArrowBtn(fld)
{     
  var str  = "<ul class=\"list-image-01\">";
      str += "<li><a href=\"javascript:sortList(false, \'" + fld + "\');\">";
      str += "<img src=\"/web/shared/images/arrow/arrow-top-01.gif\" alt=\"昇順\" class=\"rollover\" /></a></li>";
      str += "<li><a href=\"javascript:sortList(true,\'" + fld + "\');\">";
      str += "<img src=\"/web/shared/images/arrow/arrow-bottom-02.gif\" alt=\"降順\" class=\"rollover\" /></a></li>";
      str += "</ul>";

  return str;
}

// ---- ETF一覧表示処理 ----
function etf_list()
{
  // 基本情報(table1)
  var str1  = "<table class=\"tbl-data-02 tbl-stripe-01\" border=\"1\" cellspacing=\"0\"><thead><tr>";
      str1 += "<th class=\"align-C w-10\" scope=\"col\">コード" + setArrowBtn("Code") + "</th>";
      str1 += "<th class=\"align-C w-30\" scope=\"col\">銘柄名" + setArrowBtn("Description_j") + "</th>";
      str1 += "<th class=\"align-C w-15\" scope=\"col\">市場" + setArrowBtn("PrimaryExchange") + "</th>";
      str1 += "<th class=\"align-C\" scope=\"col\">連動指標" + setArrowBtn("UnderlyingIndex") + "</th>";
      str1 += "<th class=\"align-C\" scope=\"col\">経費率" + setArrowBtn("ExpenseRatio") + "</th>";
      str1 += "<th class=\"align-C w-10\" scope=\"col\">資産<br />クラス" + setArrowBtn("AssetClass") + "</th>";
      str1 += "<th class=\"align-C w-10\" scope=\"col\">投資地域" + setArrowBtn("Geography") + "</th>";
      str1 += "<th class=\"align-C w-10\" scope=\"col\">外部情報</th>";
      str1 += "</tr></thead><tbody class=\"v-align-M\">";

  // パフォーマンス(table2)
  var str2  = "<table class=\"tbl-data-02 tbl-stripe-01\" border=\"1\" cellspacing=\"0\"><thead><tr>";
      str2 += "<th class=\"align-C w-10\" scope=\"col\">コード" + setArrowBtn("Code") + "</th>";
      str2 += "<th class=\"align-C w-30\" scope=\"col\">銘柄名" + setArrowBtn("Description_j") + "</th>";
      str2 += "<th class=\"align-C\" scope=\"col\">騰落率<br />（1週間）" + setArrowBtn("Return1w") + "</th>";
      str2 += "<th class=\"align-C\" scope=\"col\">騰落率<br />（１ヵ月）" + setArrowBtn("Return1m") + "</th>";
      str2 += "<th class=\"align-C\" scope=\"col\">騰落率<br />（３ヵ月）" + setArrowBtn("Return3m") + "</th>";
      str2 += "<th class=\"align-C\" scope=\"col\">騰落率<br />（１年）" + setArrowBtn("Return1y") + "</th>";
      str2 += "<th class=\"align-C\" scope=\"col\">騰落率<br />（年初来）" + setArrowBtn("ReturnYTD") + "</th>";
      str2 += "</tr></thead><tbody class=\"v-align-M\">";

  // 分配金(table3)
  var str3  = "<table class=\"tbl-data-02 tbl-stripe-01\" border=\"1\" cellspacing=\"0\"><thead><tr>";
      str3 += "<th class=\"align-C w-10\" scope=\"col\">コード" + setArrowBtn("Code") + "</th>";
      str3 += "<th class=\"align-C w-30\" scope=\"col\">銘柄名" + setArrowBtn("Description_j") + "</th>";
      str3 += "<th class=\"align-C w-10\" scope=\"col\">通貨" + setArrowBtn("Currency") + "</th>";
      str3 += "<th class=\"align-C\" scope=\"col\">分配金<br />利回り" + setArrowBtn("DividendYeild") + "</th>";
      str3 += "<th class=\"align-C\" scope=\"col\">NAV(基準日)" + setArrowBtn("NetAssetValue") + "</th>";
      str3 += "</tr></thead><tbody class=\"v-align-M\">";

  // 概要(table4)
  var str4  = "<table class=\"tbl-data-02 tbl-stripe-01\" border=\"1\" cellspacing=\"0\"><thead><tr>";
      str4 += "<th class=\"align-C w-10\" scope=\"col\">コード" + setArrowBtn("Code") + "</th>";
      str4 += "<th class=\"align-C w-30\" scope=\"col\">銘柄名" + setArrowBtn("Description_j") + "</th>";
      str4 += "<th class=\"align-C w-15\" scope=\"col\">管理会社" + setArrowBtn("Issuer") + "</th>";
      str4 += "<th class=\"align-C w-80\" scope=\"col\">概要</th>";
      str4 += "</tr></thead><tbody class=\"v-align-M\">";


  data = tmpETFDB;
  
  var len  = data.length;
  var flen = factlist.length

  for(var i=0; i<len; i++) {
    var r = data[i];

    if((i % 2) == 0) {
      str1 = str1 + "<tr>";
      str2 = str2 + "<tr>";
      str3 = str3 + "<tr>";
      str4 = str4 + "<tr>";
    } else {
      str1 = str1 +  "<tr class=\"even\">";
      str2 = str2 +  "<tr class=\"even\">";
      str3 = str3 +  "<tr class=\"even\">";
      str4 = str4 +  "<tr class=\"even\">";
    }

    var pxName = "";
    var pUrl   = "";
    if(r.PrimaryExchange.indexOf("東京") >  -1) {
      pUrl   = "https://www.rakuten-sec.co.jp/web/market/search/quote.html?ric=" + r.Code + ".T";
      pxName = "東証";
    } else if(r.PrimaryExchange.indexOf("大阪") >  -1) {
      pUrl   = "https://www.rakuten-sec.co.jp/web/market/search/quote.html?ric=" + r.Code + ".OS";
      pxName = "大証";
    } else if(r.PrimaryExchange.indexOf("名古屋") >  -1) {
      pUrl   = "https://www.rakuten-sec.co.jp/web/market/search/quote.html?ric=" + r.Code + ".NG";
      pxName = "名証";
    } else if(r.PrimaryExchange.indexOf("香港") >  -1) {
      pUrl   = "https://www.rakuten-sec.co.jp/web/market/search/china_search/quote.html?ric=" + r.Code.substring(1,5) + ".HK";
      pxName = "香港";
    } else if(r.PrimaryExchange.indexOf("ニューヨーク") >  -1) {
      pUrl   = "https://www.rakuten-sec.co.jp/web/market/search/us_search/quote.html?ric=" + r.Code + ".P";
      pxName = "NYSE Arca";
    } else if(r.PrimaryExchange.indexOf("ナスダック") > -1) {
      pUrl   = "https://www.rakuten-sec.co.jp/web/market/search/us_search/quote.html?ric=" + r.Code + ".O";
      pxName = "NASDAQ";
    } else if(r.PrimaryExchange.indexOf("シンガポール") > -1) {
      pUrl   = "https://www.rakuten-sec.co.jp/web/market/search/asean_search/quote.html?ric=" + r.Code + ".SI";
      pxName = "シンガポール";
    }

    // 基本情報(table1)
    if(pUrl.length > 1) {
      str1 = str1 + "<th class=\"align-C\" scope=\"row\"><a href=\"" + pUrl + "\">" + r.Code + "</a></th>";
      str1 = str1 + "<td><a href=\"" + pUrl + "\">" + r.Description_j + "</a></td>";
    } else {
      str1 = str1 + "<th class=\"align-C\" scope=\"row\">" + r.Code + "</th>";
      str1 = str1 + "<td>" + r.Description_j + "</td>";
    }
    str1 = str1 + "<td class=\"align-C\">" + pxName + "</td>";
    str1 = str1 + "<td>" + r.UnderlyingIndex + "</td>";
    str1 = str1 + "<td class=\"align-R\">" + r.ExpenseRatio + "</td>";
    str1 = str1 + "<td class=\"align-C\">" + r.AssetClass + "</td>";
    str1 = str1 + "<td class=\"align-C\">" + r.Geography + "</td>";
    str1 = str1 + "<td class=\"align-C\">";

    for(var p=0; p<flen; p++) {
      if(r.Code == factlist[p][0]) {
        if(factlist[p][1])
          str1 = str1 + "<a href=\"" + factlist[p][1] + "\" target=\"_blank\"><img height=\"14\" width=\"14\" title=\"ファクトシート\" src=\"/web/shared/images/icon/icon-pdf-01.gif\"/></a>";
        if(factlist[p][2])
          str1 = str1 + " <a href=\"" + factlist[p][2] + "\" target=\"_blank\"><img height=\"14\" width=\"14\" title=\"銘柄詳細のサイトへ\" src=\"/web/shared/images/icon/icon-outside-01.gif\"/></a>";
        break;
      }
    }
    str1 = str1 + "</td>";
    str1 = str1 + "</tr>";

    // パフォーマンス(table2)
    if(pUrl.length > 1) {
      str2 = str2 + "<th class=\"align-C\" scope=\"row\"><a href=\"" + pUrl + "\">" + r.Code + "</a></th>";
      str2 = str2 + "<td><a href=\"" + pUrl + "\">" + r.Description_j + "</a></td>";
    } else {
      str2 = str2 + "<th class=\"align-C\" scope=\"row\">" + r.Code + "</th>";
      str2 = str2 + "<td>" + r.Description_j + "</td>";
    }
    str2 = str2 + "<td class=\"align-R\">" + r.Return1w  + "</td>";
    str2 = str2 + "<td class=\"align-R\">" + r.Return1m  + "</td>";
    str2 = str2 + "<td class=\"align-R\">" + r.Return3m  + "</td>";
    str2 = str2 + "<td class=\"align-R\">" + r.Return1y  + "</td>";
    str2 = str2 + "<td class=\"align-R\">" + r.ReturnYTD + "</td>";
    str2 = str2 + "</tr>";

    // 分配金(table3)
    if(pUrl.length > 1) {
      str3 = str3 + "<th class=\"align-C\" scope=\"row\"><a href=\"" + pUrl + "\">" + r.Code + "</a></th>";
      str3 = str3 + "<td><a href=\"" + pUrl + "\">" + r.Description_j + "</a></td>";
    } else {
      str3 = str3 + "<th class=\"align-C\" scope=\"row\">" + r.Code + "</th>";
      str3 = str3 + "<td>" + r.Description_j + "</td>";
    }
    str3 = str3 + "<td class=\"align-C\">" + r.Currency  + "</td>";
    str3 = str3 + "<td class=\"align-R\">" + r.DividendYeild  + "</td>";
    str3 = str3 + "<td class=\"align-R\">" + r.NetAssetValue + " (" + r.NavDate + ")"  + "</td>";
    str3 = str3 + "</tr>";

    // 概要(table4)
    if(pUrl.length > 1) {
      str4 = str4 + "<th class=\"align-C\" scope=\"row\"><a href=\"" + pUrl + "\">" + r.Code + "</a></th>";
      str4 = str4 + "<td><a href=\"" + pUrl + "\">" + r.Description_j + "</a></td>";
    } else {
      str4 = str4 + "<th class=\"align-C\" scope=\"row\">" + r.Code + "</th>";
      str4 = str4 + "<td>" + r.Description_j + "</td>";
    }
    str4 = str4 + "<td>" + r.Issuer  + "</td>";
    str4 = str4 + "<td class=\"connected-index\">" + r.Comment_l.replace(/。・/g,"。<br />・")  + "</td>";
    str4 = str4 + "</tr>";

  }

  // 基本情報(table1)
  str1 = str1 + "</tbody></table>";
  $("#table1").html(str1);

  // パフォーマンス(table2)
  str2 = str2 + "</tbody></table>";
  $("#table2").html(str2);

  // 分配金(table3)
  str3 = str3 + "</tbody></table>";
  $("#table3").html(str3);

  // パフォーマンス(table3)
  str4 = str4 + "</tbody></table>";
  $("#table4").html(str4);


}
// ---- ETF一覧表示処理 ----

// ---- URLパラメータ解析処理 ----
function getUrlVars()
{     
  var vars = [], hash;
  var hashes = window.location.href.slice(window.location.href.indexOf('?') + 1).split('&');

  for(var i = 0; i < hashes.length; i++) {
    hash = hashes[i].split('=');
    vars.push(hash[0]);
    vars[hash[0]] = decodeURI(hash[1]);
  }
  
  return vars;
}
// ---- URLパラメータ解析処理 ----

// ---- ETF検索項目抽出処理 ----
function etf_fetch()
{

  tmpETFDB = [];

  var j = 0;
  data = ETFDB;
  for(var i=0; i<data.numCode; i++) {
    var r = data.docs[i];

    // キーワード
    var kflg = 0;
    kwd = $("input[name=form-text-01]").val();
    if(kwd.length == 0) {
      kflg = 1;
    } else {
      if((r.Code.indexOf(kwd) > -1)            ||
         (r.Description_j.indexOf(kwd) > -1)   ||
         (r.Description_e.indexOf(kwd) > -1)   ||
         (r.UnderlyingIndex.indexOf(kwd) > -1) ||
         (r.Comment_s.indexOf(kwd) > -1)       ||
         (r.Comment_l.indexOf(kwd) > -1)       ||
         (r.Issuer.indexOf(kwd) > -1)          ||
         (r.Portfolio.indexOf(kwd) > -1)       ||
         (r.Feature.indexOf(kwd) > -1)         ||
         (r.Keyword.indexOf(kwd) > -1)
      ) kflg = 1;
    }

    // 上場市場
    var mflg = 0;
    if($("input[type=checkbox]:checked","#cnd-market").length == 0) {
      mflg = 1;
    } else {
      if((cbMap["mktch_jp"].flg==1) && (r.PrimaryExchange.indexOf("東京")                == 0)) { mflg = 1;
      } else if((cbMap["mktch_jp"].flg==1) && (r.PrimaryExchange.indexOf("大阪")         == 0)) { mflg = 1;
      } else if((cbMap["mktch_jp"].flg==1) && (r.PrimaryExchange.indexOf("名古屋")       == 0)) { mflg = 1;
      } else if((cbMap["mktch_hk"].flg==1) && (r.PrimaryExchange.indexOf("香港")         == 0)) { mflg = 1;
      } else if((cbMap["mktch_us"].flg==1) && (r.PrimaryExchange.indexOf("ニューヨーク") == 0)) { mflg = 1;
      } else if((cbMap["mktch_us"].flg==1) && (r.PrimaryExchange.indexOf("ナスダック")   == 0)) { mflg = 1;
      } else if((cbMap["mktch_sg"].flg==1) && (r.PrimaryExchange.indexOf("シンガポール") == 0)) { mflg = 1;
      }
    }

    // 資産タイプ
    var aflg = 0;
    if($("input[type=checkbox]:checked","#cnd-asset-type").length == 0) {
      aflg = 1;
    } else {
      if((cbMap["astch_st"].flg==1) && (r.AssetClass.indexOf("株式")          == 0)) { aflg = 1;
      } else if((cbMap["astch_bo"].flg==1) && (r.AssetClass.indexOf("債券")   == 0)) { aflg = 1;
      } else if((cbMap["astch_co"].flg==1) && (r.AssetClass.indexOf("商品")   == 0)) { aflg = 1;
      } else if((cbMap["astch_re"].flg==1) && (r.AssetClass.indexOf("不動産") == 0)) { aflg = 1;
      } else if((cbMap["astch_cu"].flg==1) && (r.AssetClass.indexOf("通貨")   == 0)) { aflg = 1;
      } else if((cbMap["astch_el"].flg==1) && (r.AssetClass.indexOf("その他") == 0)) { aflg = 1;
      }
    }

    // 投資地域
    var gflg = 0;
    if($("input[type=checkbox]:checked","#cnd-region").length == 0) {
      gflg = 1;
    } else {
      if((cbMap["geoch_jpn"].flg==1) && (r.Geography.indexOf("日本")                  == 0)) { gflg = 1;
      } else if((cbMap["geoch_sgp"].flg==1) && (r.Geography.indexOf("シンガポール")   == 0)) { gflg = 1;
      } else if((cbMap["geoch_hkg"].flg==1) && (r.Geography.indexOf("香港")           == 0)) { gflg = 1;
      } else if((cbMap["geoch_kor"].flg==1) && (r.Geography.indexOf("韓国")           == 0)) { gflg = 1;
      } else if((cbMap["geoch_twn"].flg==1) && (r.Geography.indexOf("台湾")           == 0)) { gflg = 1;
      } else if((cbMap["geoch_bra"].flg==1) && (r.Geography.indexOf("ブラジル")       == 0)) { gflg = 1;
      } else if((cbMap["geoch_mex"].flg==1) && (r.Geography.indexOf("メキシコ")       == 0)) { gflg = 1;
      } else if((cbMap["geoch_rus"].flg==1) && (r.Geography.indexOf("ロシア")         == 0)) { gflg = 1;
      } else if((cbMap["geoch_pol"].flg==1) && (r.Geography.indexOf("ポーランド")     == 0)) { gflg = 1;
      } else if((cbMap["geoch_chn"].flg==1) && (r.Geography.indexOf("中国")           == 0)) { gflg = 1;
      } else if((cbMap["geoch_aus"].flg==1) && (r.Geography.indexOf("オーストラリア") == 0)) { gflg = 1;
      } else if((cbMap["geoch_ind"].flg==1) && (r.Geography.indexOf("インド")         == 0)) { gflg = 1;
      } else if((cbMap["geoch_mys"].flg==1) && (r.Geography.indexOf("マレーシア")     == 0)) { gflg = 1;
      } else if((cbMap["geoch_idn"].flg==1) && (r.Geography.indexOf("インドネシア")   == 0)) { gflg = 1;
      } else if((cbMap["geoch_tha"].flg==1) && (r.Geography.indexOf("タイ")           == 0)) { gflg = 1;
      } else if((cbMap["geoch_phl"].flg==1) && (r.Geography.indexOf("フィリピン")     == 0)) { gflg = 1;
      } else if((cbMap["geoch_vnm"].flg==1) && (r.Geography.indexOf("ベトナム")       == 0)) { gflg = 1;
      } else if((cbMap["geoch_sam"].flg==1) && (r.Geography.indexOf("南アメリカ")     == 0)) { gflg = 1;
      } else if((cbMap["geoch_tur"].flg==1) && (r.Geography.indexOf("トルコ")         == 0)) { gflg = 1;
      } else if((cbMap["geoch_glb"].flg==1) && (r.Geography.indexOf("国際")           == 0)) { gflg = 1;
      } else if((cbMap["geoch_eur"].flg==1) && (r.Geography.indexOf("ヨーロッパ")     == 0)) { gflg = 1;
      } else if((cbMap["geoch_pac"].flg==1) && (r.Geography.indexOf("太平洋")         == 0)) { gflg = 1;
      } else if((cbMap["geoch_aem"].flg==1) && (r.Geography.indexOf("アジア新興諸国") == 0)) { gflg = 1;
      } else if((cbMap["geoch_emg"].flg==1) && (r.Geography.indexOf("新興諸国")       == 0)) { gflg = 1;
      } else if((cbMap["geoch_asa"].flg==1) && (r.Geography.indexOf("アジア")         == 0)) { gflg = 1;
      } else if((cbMap["geoch_zaf"].flg==1) && (r.Geography.indexOf("南アフリカ")     == 0)) { gflg = 1;
      } else if((cbMap["geoch_usa"].flg==1) && (r.Geography.indexOf("アメリカ")       == 0)) { gflg = 1;
      } else if((cbMap["geoch_dom"].flg==1) && (r.Geography.indexOf("国内保管型")     == 0)) { gflg = 1;
      }
    }

    // 管理会社
    var iflg = 0;
    var sel = $("#form-select-01").val();
    if(sel.indexOf("NONE") == 0) {
      iflg = 1;
    } else {
      if(r.Issuer == sel) iflg = 1;
    }
    
    // 通貨
    var cflg = 0;
    if($("input[type=checkbox]:checked","#cnd-currency").length == 0) {
      cflg = 1;
    } else {
      if((cbMap["curch_jp"].flg==1) && (r.Currency.indexOf("円")              == 0)) { cflg = 1;
      } else if((cbMap["curch_us"].flg==1) && (r.Currency.indexOf("米ドル")   == 0)) { cflg = 1;
      } else if((cbMap["curch_hk"].flg==1) && (r.Currency.indexOf("香港ドル") == 0)) { cflg = 1;
      }
    }

    // 経費率
    var eflg = 0;
    if($("input[type=checkbox]:checked","#cnd-cost-ratio").length == 0) {
      eflg = 1;
    } else {
      var exr = parseFloat(r.ExpenseRatio);
      if((cbMap["exrch_1"].flg==1) &&                          (exr < 0.5)) { eflg = 1;
      } else if((cbMap["exrch_2"].flg==1) && ((exr >= 0.5) && (exr < 1.0))) { eflg = 1;
      } else if((cbMap["exrch_3"].flg==1) &&                  (exr >= 1.0)) { eflg = 1;
      }
    }

    if((kflg == 1) && (mflg == 1) && (aflg == 1) && (gflg == 1) && (iflg == 1) && (eflg == 1) && (cflg == 1)) {
      tmpETFDB[j] = r;
      j = j + 1;
    }
  }

  
  // 検索件数表示
  var str = "<span><strong>" + tmpETFDB.length + "</strong>件</span>";
  $(".result").html(str);
}
// ---- ETF検索項目抽出処理 ----
