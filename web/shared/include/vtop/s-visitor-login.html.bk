      </div>
      <div class="editBtnArea">
        <table cellspacing="10">
          <tr>
            <td onclick="del(0)" ondblclick="del(0)" class="btnl">1文字削除</td>
            <td onclick="del(1)" ondblclick="del(1)" class="btnl">クリア</td>
            <td onclick="closekey()" ondblclick="closekey()" class="btnl">閉じる</td>
          </tr>
        </table>
      </div>
