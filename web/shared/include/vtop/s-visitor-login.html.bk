              <td id="keyZ" onmouseover="keyon('Z')" onmouseout="keyoff('Z')" onclick="keypush('Z')" class="btns">Z</td>
              <td>&nbsp;</td>
              <td>&nbsp;</td>
              <td>&nbsp;</td>
              <td>&nbsp;</td>
            </tr>
          </table>
        </div>
        <div id="keyarea2" class="btninner">
          <table cellspacing="5">
            <tr>
              <td id="keya1" onmouseover="keyon1('a')" onmouseout="keyoff1('a')" onclick="keypush1('a')" class="btns">a</td>
              <td id="keyb1" onmouseover="keyon1('b')" onmouseout="keyoff1('b')" onclick="keypush1('b')" class="btns">b</td>
              <td id="keyc1" onmouseover="keyon1('c')" onmouseout="keyoff1('c')" onclick="keypush1('c')" class="btns">c</td>
              <td id="keyd1" onmouseover="keyon1('d')" onmouseout="keyoff1('d')" onclick="keypush1('d')" class="btns">d</td>
              <td id="keye1" onmouseover="keyon1('e')" onmouseout="keyoff1('e')" onclick="keypush1('e')" class="btns">e</td>
              <td id="keyf1" onmouseover="keyon1('f')" onmouseout="keyoff1('f')" onclick="keypush1('f')" class="btns">f</td>
