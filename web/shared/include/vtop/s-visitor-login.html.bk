            </tr>
            <tr>
              <td id="keyK" onmouseover="keyon('K')" onmouseout="keyoff('K')" onclick="keypush('K')" class="btns">K</td>
              <td id="keyL" onmouseover="keyon('L')" onmouseout="keyoff('L')" onclick="keypush('L')" class="btns">L</td>
