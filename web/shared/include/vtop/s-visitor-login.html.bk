<!-- ============ソフトウェアキーボード============ -->
<div class="softwarekeyboard">
  <div id="keyboard" class="keyboard">
    <div class="keyinner">
      <h2>ソフトウェアキーボード</h2>
      <p class="closeBtn"><a href="javascript:;" onclick="closekey()" ondblclick="closekey()">閉じる</a></p>
      <div class="tab">
        <ul>
          <li id="key_tab0"><img src="/web/shared/img/keyboard_tab_idon.gif" width="100" height="26" alt="ログインID"></li>
          <li id="key_tab1"><img src="/web/shared/img/keyboard_tab_passoff.gif" width="100" height="26" alt="パスワード"></li>
        </ul>
        <p><a href="/web/info/software_keyboard.html">使用方法</a></p>
      </div>
      <div id="btnArea" class="btnArea">
        <div id="keyarea0" class="btninner">
          <table cellspacing="5">
            <tr>
              <td id="key0" onmouseover="keyon('0')" onmouseout="keyoff('0')" onclick="keypush('0')" class="btns">0</td>
              <td id="key1" onmouseover="keyon('1')" onmouseout="keyoff('1')" onclick="keypush('1')" class="btns">1</td>
              <td id="key2" onmouseover="keyon('2')" onmouseout="keyoff('2')" onclick="keypush('2')" class="btns">2</td>
              <td id="key3" onmouseover="keyon('3')" onmouseout="keyoff('3')" onclick="keypush('3')" class="btns">3</td>
              <td id="key4" onmouseover="keyon('4')" onmouseout="keyoff('4')" onclick="keypush('4')" class="btns">4</td>
              <td id="key5" onmouseover="keyon('5')" onmouseout="keyoff('5')" onclick="keypush('5')" class="btns">5</td>
              <td id="key6" onmouseover="keyon('6')" onmouseout="keyoff('6')" onclick="keypush('6')" class="btns">6</td>
              <td id="key7" onmouseover="keyon('7')" onmouseout="keyoff('7')" onclick="keypush('7')" class="btns">7</td>
              <td id="key8" onmouseover="keyon('8')" onmouseout="keyoff('8')" onclick="keypush('8')" class="btns">8</td>
              <td id="key9" onmouseover="keyon('9')" onmouseout="keyoff('9')" onclick="keypush('9')" class="btns">9</td>
            </tr>
          </table>
        </div>
        <div id="keyarea1" class="btninner">
          <table cellspacing="5">
            <tr>
              <td id="keyA" onmouseover="keyon('A')" onmouseout="keyoff('A')" onclick="keypush('A')" class="btns">A</td>
              <td id="keyB" onmouseover="keyon('B')" onmouseout="keyoff('B')" onclick="keypush('B')" class="btns">B</td>
              <td id="keyC" onmouseover="keyon('C')" onmouseout="keyoff('C')" onclick="keypush('C')" class="btns">C</td>
              <td id="keyD" onmouseover="keyon('D')" onmouseout="keyoff('D')" onclick="keypush('D')" class="btns">D</td>
