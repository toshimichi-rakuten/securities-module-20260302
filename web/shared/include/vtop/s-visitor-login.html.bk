            </tr>
            <tr>
              <td id="keyk1" onmouseover="keyon1('k')" onmouseout="keyoff1('k')" onclick="keypush1('k')" class="btns">k</td>
              <td id="keyl1" onmouseover="keyon1('l')" onmouseout="keyoff1('l')" onclick="keypush1('l')" class="btns">l</td>
              <td id="keym1" onmouseover="keyon1('m')" onmouseout="keyoff1('m')" onclick="keypush1('m')" class="btns">m</td>
              <td id="keyn1" onmouseover="keyon1('n')" onmouseout="keyoff1('n')" onclick="keypush1('n')" class="btns">n</td>
              <td id="keyo1" onmouseover="keyon1('o')" onmouseout="keyoff1('o')" onclick="keypush1('o')" class="btns">o</td>
              <td id="keyp1" onmouseover="keyon1('p')" onmouseout="keyoff1('p')" onclick="keypush1('p')" class="btns">p</td>
              <td id="keyq1" onmouseover="keyon1('q')" onmouseout="keyoff1('q')" onclick="keypush1('q')" class="btns">q</td>
              <td id="keyr1" onmouseover="keyon1('r')" onmouseout="keyoff1('r')" onclick="keypush1('r')" class="btns">r</td>
              <td id="keys1" onmouseover="keyon1('s')" onmouseout="keyoff1('s')" onclick="keypush1('s')" class="btns">s</td>
              <td id="keyt1" onmouseover="keyon1('t')" onmouseout="keyoff1('t')" onclick="keypush1('t')" class="btns">t</td>
            </tr>
